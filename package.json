{
  "name": "hyper-nat",
  "version": "2.0.0",
  "description": "Securely tunnel UDP and TCP connections over peer-to-peer networks using hyperswarm for NAT traversal",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:css": "node node_modules/tailwindcss/lib/cli.js --input src/renderer/styles/input.css --output src/renderer/styles/output.css",
    "build:vendor": "node scripts/build-vendor.js",
    "build:dist": "electron-builder",
    "build": "node scripts/build-vendor.js && node node_modules/tailwindcss/lib/cli.js --input src/renderer/styles/input.css --output src/renderer/styles/output.css",
    "dev": "electron ."
  },
  "keywords": [
    "udp",
    "tcp",
    "tcpudp",
    "tunnel",
    "p2p",
    "nat",
    "hyperswarm",
    "forwarding",
    "networking",
    "tcp-over-udp"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/username/hyper-nat.git"
  },
  "bugs": {
    "url": "https://github.com/username/hyper-nat/issues"
  },
  "homepage": "https://github.com/username/hyper-nat#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hyperswarm/dht": "^6.5.1",
    "bs58": "^6.0.0",
    "electron": "^41.0.3",
    "keypear": "^1.2.2",
    "pump": "^3.0.3",
    "readline": "^1.3.0",
    "rippleui": "^1.12.1",
    "webjsx": "^0.0.73",
    "xstate": "^5.28.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.27",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  },
  "build": {
    "appId": "com.hyper-nat.app",
    "productName": "Hyper-NAT",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "lib/**/*",
      "vendor/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
